@model HelpDesk.Models.Ticket

@{

    ViewData["Title"] = "tickesss";
}


<div class="container mt-4"> 
    <div>
        <h1 class="text-center">

            Gestion de ticketes
        </h1>

    </div>
   

    <div class="d-flex justify-content-between align-items-center mb-3">
      

      

        <div class="row">
            <div class=" shadow-sm p-4 border rounded"> 
                <form asp-action="Create" >

                    <div class="mb-3"> 
                        <label asp-for="Titulo" class="form-label">Titulo ticket</label>
                        <input asp-for="Titulo" class="form-control" />
                        <span asp-validation-for="Titulo"class="text-danger"> </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Titulo ticket</label>
                        <textarea asp-for="Descripcion" class="form-control"> </textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"> </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Prioridad" class="form-label">Prioridad</label>

                        <select asp-for="Prioridad" class="form-select">
    <option value="Baja">Baja</option>
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
</select>


                        <div class="mb-3">
                         <button type="submit" class="btn btn-success">Crear</button>
                         <a asp-action="Index" >Volver</a>
                        </div>

                      
                    </div>
                </form>
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary">Crear nuevo ticket  </a>


    </div>

</div>


                            @section Scripts {
                            
@{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
                            }
